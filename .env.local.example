# Sanity — create a project at https://sanity.io/manage or run: npx sanity@latest init
NEXT_PUBLIC_SANITY_PROJECT_ID=
NEXT_PUBLIC_SANITY_DATASET=production
NEXT_PUBLIC_SANITY_API_VERSION=2025-01-01

# Server-only (migration script + draft preview later)
SANITY_API_READ_TOKEN=
SANITY_API_WRITE_TOKEN=

# Hosted Studio (`npx sanity deploy`) — the Vite build only exposes SANITY_STUDIO_*
# vars, so mirror the public values here. BASEPATH=/ serves the Studio at the
# subdomain root; the embedded /studio route ignores these.
SANITY_STUDIO_PROJECT_ID=
SANITY_STUDIO_DATASET=production
SANITY_STUDIO_API_VERSION=2025-01-01
SANITY_STUDIO_BASEPATH=/
